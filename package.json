{
  "name": "atourin-directory-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "db:types": "supabase gen types typescript --local --schema directory > src/types/supabase.ts",
    "db:diff": "supabase db diff --schema directory",
    "db:push": "supabase db push",
    "db:pull": "supabase db pull --schema directory",
    "db:reset": "supabase db reset",
    "db:reset:dir": "supabase migration new reset_directory_schema && echo 'Edit the new migration file, then run npm run db:push'",
    "gen:blur": "node scripts/gen-blur.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.3",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/nextjs-vite": "^10.4.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "plaiceholder": "^3.0.0",
    "playwright": "^1.61.1",
    "sharp": "^0.35.3",
    "storybook": "^10.4.6",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
